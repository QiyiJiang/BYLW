# ========== API 密钥（必填，用于请求各服务） ==========
# Embedding 服务（如硅基流动 BGE）
EMBEDDING_API_KEY=your-embedding-api-key
# LLM 聊天服务（如硅基流动 Qwen）
SILICONFLOW_LLM_API_KEY=your-llm-api-key

# ========== Embedding 配置（对应 config/api.yaml embedding） ==========
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_TIMEOUT=30

# ========== LLM 配置（对应 config/api.yaml llm） ==========
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3-32B
LLM_TIMEOUT=60

# ========== 限流（对应 config/api.yaml rate_limits） ==========
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=60
RATE_LIMIT_MAX_PARALLEL_REQUESTS=4

# ========== 实验/路径（可选，对应 config/experiment.yaml 与 config/paths.yaml） ==========
# RANDOM_SEED=42
# DATA_RAW_DIR=data/raw
# DATA_PROCESSED_DIR=data/processed
# MILVUS_DB_PATH=data/milvus/db
